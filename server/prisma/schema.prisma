generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  passwordHash  String
  role          Role           @default(CUSTOMER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orders        Order[]
  wishlist      WishlistItem[]
  refreshTokens RefreshToken[]
}

/// Refresh tokens are stored only as SHA-256 hashes so a DB leak can't be
/// replayed. Rotated on every use; revoked on logout.
model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Product {
  id            String         @id
  name          String
  brand         String
  category      String
  price         Int
  salePrice     Int?
  badge         String?
  rating        Float?
  reviews       Int            @default(0)
  colors        String[]
  sizes         Int[]
  imageUrl      String?
  gallery       String[]
  isNew         Boolean        @default(false)
  soldOut       Boolean        @default(false)
  lowStock      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]

  @@index([brand])
}

model Order {
  id           String      @id @default(cuid())
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  status       OrderStatus @default(PENDING)
  customerName String
  phone        String
  note         String?
  total        Int
  items        OrderItem[]
  createdAt    DateTime    @default(now())

  @@index([userId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  size      Int?
  color     String?
  qty       Int
  price     Int

  @@index([orderId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}
