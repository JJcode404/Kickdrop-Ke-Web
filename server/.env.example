# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/kickdrop_db

# --- Server ---
NODE_ENV=development
PORT=4000

# Comma-separated list of allowed browser origins (your frontend).
CLIENT_ORIGINS=http://localhost:5173

# --- Auth secrets ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me-too

# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Cookie domain (leave blank for host-only cookies in development)
COOKIE_DOMAIN=
